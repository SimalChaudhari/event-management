# API
VITE_API_BASE_URL=http://localhost:5000
VITE_API_NODE_ENV=development
VITE_API_TIMEOUT=15000
VITE_API_RETRY_ATTEMPTS=3
VITE_API_RETRY_DELAY=1000

# Uploads / static assets (optional; defaults to API base)
VITE_UPLOADS_URL=http://localhost:5000

# App download (optional; used for footer QR codes and links)
# VITE_APP_DOWNLOAD_URL=https://evential.sg
# VITE_APP_STORE_URL=https://apps.apple.com/app/...
# VITE_PLAY_STORE_URL=https://play.google.com/store/apps/...

# Optional
VITE_ENABLE_LOGGING=false
