# Production – used when you run: npm run build
# Vite loads .env.production automatically during build.

# Your production backend URL
VITE_API_BASE_URL=https://app.evential.sg:5000
VITE_API_NODE_ENV=production

VITE_API_TIMEOUT=15000
VITE_API_RETRY_ATTEMPTS=3
VITE_API_RETRY_DELAY=1000
VITE_UPLOADS_URL=https://app.evential.sg:5000

VITE_ENABLE_LOGGING=false
VITE_APP_DOWNLOAD_URL=https://evential.sg
