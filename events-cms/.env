# REACT_APP_API_URL = "https://app.evential.sg:5000"

REACT_APP_API_URL = "http://localhost:5000"
# 
# REACT_APP_API_NODE="Development"

REACT_APP_API_NODE_ENV = ""

# Leave empty in dev to use CRA proxy (avoids CORS when switching between event-web and event-cms).
REACT_APP_API_BASE_URL=
# REACT_APP_API_BASE_URL="http://localhost:5000"
# REACT_APP_API_BASE_URL="https://app.evential.sg:5000"



REACT_APP_API_TIMEOUT=15000
REACT_APP_API_RETRY_ATTEMPTS=5
REACT_APP_API_RETRY_DELAY=2000
REACT_APP_ENABLE_LOGGING=true

# Stops "Failed to parse source map" warnings from node_modules (e.g. html5-qrcode).
# Trade-off: browser devtools will show compiled code instead of original source.
# GENERATE_SOURCEMAP=false

# HTTPS=true
# SSL_CRT_FILE=D:/event-management/events-backend/ssl/app.evential.sg-chain.pem
# SSL_KEY_FILE=D:/event-management/events-backend/ssl/app.evential.sg-key.pem