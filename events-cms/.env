REACT_APP_API_URL = "https://events.isca.org.sg:5000"

# REACT_APP_API_URL = "http://localhost:5000"
# 
# REACT_APP_API_NODE="Development"

REACT_APP_API_NODE_ENV = ""

# REACT_APP_API_BASE_URL="http://localhost:5000"

REACT_APP_API_BASE_URL="https://events.isca.org.sg:5000"



REACT_APP_API_TIMEOUT=15000
REACT_APP_API_RETRY_ATTEMPTS=5
REACT_APP_API_RETRY_DELAY=2000
REACT_APP_ENABLE_LOGGING=true

HTTPS=true
SSL_CRT_FILE=D:/event-management/events-backend/ssl/events.isca.org.sg-chain.pem
SSL_KEY_FILE=D:/event-management/events-backend/ssl/events.isca.org.sg-key.pem