# Production – copy to .env.production or set when building/running in production.

REACT_APP_API_URL=https://app.evential.sg:5000
REACT_APP_API_BASE_URL=https://app.evential.sg:5000
REACT_APP_API_NODE_ENV=production

# Allow access via domain/IP (stops "Invalid Host header" when not using localhost)
DANGEROUSLY_DISABLE_HOST_CHECK=true

REACT_APP_API_TIMEOUT=15000
REACT_APP_API_RETRY_ATTEMPTS=5
REACT_APP_API_RETRY_DELAY=2000
REACT_APP_ENABLE_LOGGING=false
GENERATE_SOURCEMAP=false
