{
  "info": {
    "name": "Event QR Code & Scanner System",
    "description": "Complete API collection for QR code and scanner functionality",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "jwtToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "eventId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('jwtToken', response.access_token);",
                  "    pm.environment.set('userId', response.user.id);",
                  "    console.log('JWT Token saved:', response.access_token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "User QR Code",
      "item": [
        {
          "name": "Get User QR Code (Admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/qr-code/attendance/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "qr-code", "attendance", "{{userId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Event QR Code (Simple)",
      "item": [
        {
          "name": "Generate Simple Event QR Code (Admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/attendance/event-qr-code/generate/{{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "event-qr-code", "generate", "{{eventId}}"]
            }
          }
        },
        {
          "name": "Scan Simple Event QR Code (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/attendance/event-qr-code/scan/{{eventQRCodeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "event-qr-code", "scan", "{{eventQRCodeId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Attendance Management",
      "item": [
        {
          "name": "Scan QR Code for Attendance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"qrCodeData\": \"user_12345_attendance\",\n  \"eventId\": \"{{eventId}}\",\n  \"location\": \"Main Entrance\",\n  \"notes\": \"Checked in via QR scan\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/attendance/scan-qr-code",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "scan-qr-code"]
            }
          }
        },
        {
          "name": "Manual Check-in",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"eventId\": \"{{eventId}}\",\n  \"location\": \"Registration Desk\",\n  \"notes\": \"Manual check-in by admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/attendance/manual-check-in",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "manual-check-in"]
            }
          }
        },
        {
          "name": "Check-out User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"eventId\": \"{{eventId}}\",\n  \"notes\": \"User checked out\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/attendance/check-out",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "check-out"]
            }
          }
        },
        {
          "name": "Get Event Attendance",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/attendance/event/{{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "event", "{{eventId}}"]
            }
          }
        },
        {
          "name": "Get Event Attendance Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/attendance/event/{{eventId}}/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "event", "{{eventId}}", "stats"]
            }
          }
        }
      ]
    },
    {
      "name": "Event QR Code Management (Admin)",
      "item": [
        {
          "name": "Create Event QR Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"type\": \"check_in\",\n  \"title\": \"Main Entrance Check-in\",\n  \"description\": \"QR code for main entrance check-in\",\n  \"location\": \"Main Entrance\",\n  \"allowSelfCheckIn\": true,\n  \"autoRegister\": true,\n  \"redirectToPayment\": false,\n  \"maxScans\": 1000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/attendance/event-qr-codes/create",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "event-qr-codes", "create"]
            }
          }
        },
        {
          "name": "Create Contact Exchange QR Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"type\": \"contact_exchange\",\n  \"title\": \"Networking Area\",\n  \"description\": \"QR code for contact exchange\",\n  \"location\": \"Networking Lounge\",\n  \"allowSelfCheckIn\": false,\n  \"autoRegister\": false,\n  \"redirectToPayment\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/attendance/event-qr-codes/create",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "event-qr-codes", "create"]
            }
          }
        },
        {
          "name": "Create Exhibitor Stamp QR Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"type\": \"exhibitor_stamp\",\n  \"title\": \"TechCorp Booth\",\n  \"description\": \"QR code for TechCorp booth stamp collection\",\n  \"location\": \"Booth A1\",\n  \"allowSelfCheckIn\": false,\n  \"autoRegister\": false,\n  \"redirectToPayment\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/attendance/event-qr-codes/create",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "event-qr-codes", "create"]
            }
          }
        },
        {
          "name": "Get Event QR Codes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/attendance/event-qr-codes/event/{{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "event-qr-codes", "event", "{{eventId}}"]
            }
          }
        },
        {
          "name": "Get QR Code Image",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/attendance/event-qr-codes/{{qrCodeId}}/image",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "event-qr-codes", "{{qrCodeId}}", "image"]
            }
          }
        }
      ]
    },
    {
      "name": "User Self-Service",
      "item": [
        {
          "name": "Self Check-in",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"qrCodeData\": \"{{eventQRCodeId}}\",\n  \"location\": \"Main Entrance\",\n  \"notes\": \"Self check-in via mobile app\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/attendance/self-check-in",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "self-check-in"]
            }
          }
        },
        {
          "name": "Contact Exchange",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scannedUserId\": \"{{scannedUserId}}\",\n  \"eventId\": \"{{eventId}}\",\n  \"location\": \"Networking Lounge\",\n  \"notes\": \"Met at networking event\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/attendance/contact-exchange",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "contact-exchange"]
            }
          }
        },
        {
          "name": "Collect Exhibitor Stamp",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventQRCodeId\": \"{{exhibitorQRCodeId}}\",\n  \"eventId\": \"{{eventId}}\",\n  \"notes\": \"Visited TechCorp booth\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/attendance/exhibitor-stamp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "exhibitor-stamp"]
            }
          }
        },
        {
          "name": "Get My Contact Exchanges",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/attendance/contact-exchanges?eventId={{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "contact-exchanges"],
              "query": [
                {
                  "key": "eventId",
                  "value": "{{eventId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get My Exhibitor Stamps",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/attendance/exhibitor-stamps?eventId={{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendance", "exhibitor-stamps"],
              "query": [
                {
                  "key": "eventId",
                  "value": "{{eventId}}"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
